.DS_Store
**/.DS_Store
Thumbs.db
desktop.ini

# =========================
# Environment Variables
# =========================
.env
.env.*
!.env.example

# =========================
# Python / Backend
# =========================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# uv & Virtual Environments
.venv/
.env/
venv/
env/
# Note: Do NOT ignore uv.lock, it should be committed for reproducible builds.

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Testing & Coverage
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/
.nox/

# Type Checking
.mypy_cache/
.pyre/

# Jupyter
.ipynb_checkpoints/

